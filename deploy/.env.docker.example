# Copy to deploy/.env.docker and fill values before running compose.

# --- Runtime ports ---
WEB_PORT=80
VITE_BASE_PATH=/

# --- Database ---
POSTGRES_DB=erp_saas
POSTGRES_USER=erp
POSTGRES_PASSWORD=change-me

# --- Backend security ---
# Generate with: openssl rand -base64 64
JWT_SECRET=replace-me-with-long-random-secret
JWT_EXPIRATION_MS=86400000

# Frontend URL used in emails and security validation
FRONTEND_BASE_URL=https://app.example.com
CORS_ALLOWED_ORIGINS=https://app.example.com

# Optional mail settings (for self-service forgot-password)
MAIL_FROM=noreply@example.com
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
